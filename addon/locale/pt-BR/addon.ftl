# addon.ftl — Traduções em português (Brasil) para o plugin UFC-ABNT
#
# Formato: Project Fluent (Mozilla)
# Cada identificador aqui é referenciado no XHTML e no código TypeScript
# via data-l10n-id="identificador".
#
# Convenção de nomes:
#   pref-*     → textos da tela de preferências
#   startup-*  → mensagens durante inicialização
#   general-*  → textos genéricos do plugin

# --- Preferências ---
pref-title = UFC-ABNT — Preferências
pref-postprocess-title = Pós-processamento de referências
pref-postprocess-enable = Ativar correções automáticas
pref-postprocess-description =
    Aplica ajustes às referências geradas pelo CSL que não podem ser
    expressos nativamente no formato CSL (ex: subtítulo fora do negrito,
    conversão de en-dash para hífen em páginas).

# --- Inicialização ---
startup-csl-installed = Estilo UFC-ABNT instalado com sucesso.
startup-csl-updated = Estilo UFC-ABNT atualizado para versão { $version }.
startup-csl-already-current = Estilo UFC-ABNT já está na versão atual.
