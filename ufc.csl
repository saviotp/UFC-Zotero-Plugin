<?xml version="1.0" encoding="utf-8"?>
<style xmlns="http://purl.org/net/xbiblio/csl" version="1.0" class="in-text" demote-non-dropping-particle="never" default-locale="pt-BR">
  <info>
    <title>Universidade Federal do Ceará - ABNT (Português - Brasil)</title>
    <title-short>UFC-ABNT</title-short>
    <id>http://www.zotero.org/styles/universidade-federal-do-ceara-abnt</id>
    <link href="https://github.com/saviotp/ufc-zotero-plugin" rel="self"/>
    <link href="http://www.zotero.org/styles/associacao-brasileira-de-normas-tecnicas" rel="template"/>
    <link href="https://biblioteca.ufc.br/wp-Ccontent/uploads/2023/12/guianormalizacaoreferencias.pdf" rel="documentation"/>
    <link href="https://biblioteca.ufc.br/wp-content/uploads/2025/06/guianormalizacaocitacoes2025.pdf" rel="documentation"/>
    <author>
      <name>Sávio Teixeira Pacheco</name>
    </author>
    <contributor>
      <name>Claude (Anthropic) — assistência IA</name>
    </contributor>
    <contributor>
      <name>Antônia Cláudia Barroso Dias — Bibliotecária, Campus de Quixadá, UFC</name>
    </contributor>
    <category citation-format="author-date"/>
    <category field="generic-base"/>
    <summary>Estilo de formatação da Universidade Federal do Ceará em conformidade com ABNT-NBR 10520:2023 e ABNT-NBR 6023:2018. Baseado no estilo ABNT do repositório Zotero Styles.</summary>
    <updated>2026-03-14T00:00:00+00:00</updated>
    <rights license="http://creativecommons.org/licenses/by-sa/3.0/">This work is licensed under a Creative Commons Attribution-ShareAlike 3.0 License</rights>
  </info>
  <locale xml:lang="pt-BR">
    <terms>
      <term name="month-01" form="short">jan.</term>
      <term name="month-02" form="short">fev.</term>
      <term name="month-03" form="short">mar.</term>
      <term name="month-04" form="short">abr.</term>
      <term name="month-05" form="short">maio</term>
      <term name="month-06" form="short">jun.</term>
      <term name="month-07" form="short">jul.</term>
      <term name="month-08" form="short">ago.</term>
      <term name="month-09" form="short">set.</term>
      <term name="month-10" form="short">out.</term>
      <term name="month-11" form="short">nov.</term>
      <term name="month-12" form="short">dez.</term>
      <term name="et-al">et al</term>
      <term name="editor" form="short">
        <single>org.</single>
        <multiple>org.</multiple>
      </term>
      <term name="in">in</term>
      <term name="composer" form="long">
        <single>Compositor</single>
        <multiple>Compositores</multiple>
      </term>
      <term name="performer" form="long">
        <single>Intérprete</single>
        <multiple>Intérpretes</multiple>
      </term>
    </terms>
  </locale>
